<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net8.0-windows</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <AssemblyName>Microsoft.Xaml.Behaviors</AssemblyName>
        <Company>Microsoft Corporation</Company>
        <Product>Microsoft.Xaml.Behaviors</Product>
        <AssemblyVersion>1.1.0.0</AssemblyVersion>
        <FileVersion>1.1.135.29210</FileVersion>
        <UseWPF>true</UseWPF>
        <RootNamespace />
    </PropertyGroup>

    <ItemGroup>
      <PackageReference Include="Lib.Harmony" Version="2.4.2" />
    </ItemGroup>

    <ItemGroup>
      <Reference Include="VOCALOID6">
        <HintPath>C:\Program Files\VOCALOID6\Editor\VOCALOID6.dll</HintPath>
      </Reference>
    </ItemGroup>

    <Target Name="PostBuild" AfterTargets="PostBuildEvent">
      <Exec Command="ilrepack /ndebug /internalize:$(ProjectDir)repackexcludes.txt /out:$(OutputPath)out\Microsoft.Xaml.Behaviors.dll $(OutputPath)0Harmony.dll $(OutputPath)Microsoft.Xaml.Behaviors.dll" />
    </Target>


</Project>
